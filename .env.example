# Server configuration
PORT=5000
NODE_ENV=development

# Database configuration (PostgreSQL)
DATABASE_URL="postgresql://username:password@localhost:5432/renewal_radar?schema=public"

# JWT configuration
JWT_SECRET="your_super_secret_jwt_key_change_me_in_production"
JWT_EXPIRES_IN="7d"

# SMTP configuration for email reminders (e.g. Mailtrap for development or Gmail/Sendgrid for production)
SMTP_HOST="sandbox.smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="your_smtp_user"
SMTP_PASS="your_smtp_password"
SMTP_FROM="no-reply@renewalradar.com"
